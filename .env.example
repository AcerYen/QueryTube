# 應用程式版本（選填；未設定時使用 config/version.py 內建版號）
# APP_VERSION=1.0.0

YOUTUBE_API_KEY=your_youtube_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini 摘要模型（主模型繁忙時會依序嘗試備援模型）
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-2.0-flash-lite
# 503 等暫時性錯誤時，每個模型的重試次數（指數退避）
GEMINI_MAX_RETRIES=5

# Telegram Bot（推播與頻道管理）
# 透過 @BotFather 建立 Bot 取得 Token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# 管理員 Telegram User ID（數字），同步接收用戶動態並可使用 /status、/users、/user 等管理指令
# 可透過 @userinfobot 或 @getidsbot 查詢自己的 ID
TELEGRAM_ADMIN_ID=123456789

# LINE Messaging API（可選；兩者皆填才啟用。僅被動摘要，不做訂閱）
# 於 https://developers.line.biz/ 建立 Messaging API channel 後取得
# LINE_CHANNEL_SECRET=
# LINE_CHANNEL_ACCESS_TOKEN=
# LINE_WEBHOOK_PORT=8080

# Groq 語音轉錄（無官方字幕時的備援；https://console.groq.com/keys）
GROQ_API_KEY=your_groq_api_key_here
# 可選：whisper-large-v3-turbo（預設，較快）或 whisper-large-v3（較準）
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# 逗號分隔的 YouTube Channel ID（非 @handle，啟動時自動加入管理員的訂閱清單）
# 一般用戶也可透過 Telegram /add 指令獨立管理自己的頻道
CHANNEL_IDS=UCWMxmoBhchU3swFAciqagnw,UCV2Z0EZvFx-23JW0Tke66ew

# 每日推播時間（24 小時制，逗號分隔；預設每晚 20:00 一次）
CHECK_TIMES=20:00

# 容器時區（NAS Docker 請保持 Asia/Taipei）
TZ=Asia/Taipei

# 啟動時是否立即執行一次（NAS 正式環境建議 false）
RUN_ON_STARTUP=false

# API 呼叫間隔（秒），避免觸發免費額度限制
# YouTube Data API 每日 10,000 units；Gemini 2.5 Flash 免費層約 10 RPM / 250 RPD
YOUTUBE_API_DELAY=0.5
GEMINI_API_DELAY=6.5
TRANSCRIPT_DELAY=2.0
CHANNEL_PROCESS_DELAY=3.0
VIDEO_PROCESS_DELAY=2.0
